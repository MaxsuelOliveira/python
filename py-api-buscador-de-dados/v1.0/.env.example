VERSION="1.0.0"
LOG_LEVEL=debug
MODE=development
API_HOST=https://your-api-host.example.com/pessoas
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name

SQLITE_DB_PATH=data/db.sqlite3
API_KEY=your_api_key_here

SESSION_SECRET=change_me_session_secret
CHANNEL_ID=your_channel_id_here
ADMIN_API_KEY=change_me_admin_api_key
PAYMENT_WEBHOOK_SECRET=change_me_payment_webhook_secret

MERCADOPAGO_ACCESS_TOKEN=your_payment_api_key_here
MERCADOPAGO_BASE_UR=https://api.mercadopago.com
MERCADOPAGO_NOTIFICATION_URL=https://yourdomain.com/webhook/mercadopago

LOG_SQLITE_DB_PATH=data/logs.sqlite3
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
SMTP_FROM=your_email@example.com
